{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AMI Assist",
  "version": "0.5.0",
  "identifier": "com.transcriptionapp.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AMI Assist",
        "width": 320,
        "height": 700,
        "minWidth": 300,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost http://172.16.100.45:* http://100.119.83.76:* http://10.241.15.154:* http://192.168.*:* http://localhost:*; connect-src 'self' http://localhost:* https://localhost:* http://100.119.83.76:* http://10.241.15.154:* http://172.16.100.45:* http://127.0.0.1:* ipc: tauri:; media-src 'self' blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
        "icons/icon_32x32.png",
        "icons/icon_128x128.png",
        "icons/icon_256x256.png",
        "icons/icon_512x512.png",
        "icons/icon.icns"
      ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["fabricscribe"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/zohoora/transcriptionapp/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxN0Q2NDNGRDNGQjM5QzgKUldUSU9mdlRQMlI5d2RnQlFnQnFXazNIY1hIY3NlWUpIY1hTZ2Y5c201STFuZmJsaTd3UW1UUTkK"
    }
  }
}
